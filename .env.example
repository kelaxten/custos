# Custos Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains passwords.
# Run scripts/setup.sh to auto-generate MQTT credentials.

# ─── Camera credentials ───────────────────────────────────────────────────────
# Password for all Reolink cameras. Set via the setup wizard (custos.local/setup).
FRIGATE_RTSP_PASSWORD=your_camera_password_here

# ─── MQTT credentials ─────────────────────────────────────────────────────────
# Generated automatically by scripts/setup.sh. Used by Mosquitto, Frigate, and HA.
MQTT_USER=custos
MQTT_PASSWORD=change_me
FRIGATE_MQTT_USER=custos
FRIGATE_MQTT_PASSWORD=change_me

# ─── Storage ──────────────────────────────────────────────────────────────────
# Where recordings, snapshots, and logs are stored on the Pi's filesystem.
# Default: /opt/custos/storage — requires ~100GB free for 7-day retention on 2 cameras.
# To use an external drive: CUSTOS_STORAGE_PATH=/mnt/usb-drive/custos
CUSTOS_STORAGE_PATH=/opt/custos/storage
